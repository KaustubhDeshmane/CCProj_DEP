# -------------------------------------------------------
# Option A: Use a direct URL (takes priority over Azure vars)
# Local SQLite — good for development without Azure set up
# -------------------------------------------------------
DATABASE_URL=sqlite:///./database.db

# -------------------------------------------------------
# Option B: Azure SQL (used when DATABASE_URL is NOT set)
# Fill these in once DevOps shares the connection details
# -------------------------------------------------------
AZURE_SQL_SERVER=your-server-name.database.windows.net
AZURE_SQL_DATABASE=your-database-name
AZURE_SQL_USER=your-sql-username
AZURE_SQL_PASSWORD=your-sql-password